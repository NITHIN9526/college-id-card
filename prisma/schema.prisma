// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id           String   @id @default(cuid())
  fullName     String
  admissionNo  String   @unique
  department   String
  semester     String
  bloodGroup   String?
  address      String
  studentPhone String
  parentPhone  String
  email        String
  photoUrl     String?
  status       String   @default("pending") // pending, approved, rejected, printed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}
